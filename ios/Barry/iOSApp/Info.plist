<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Barry</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Barry uses your location to find the nearest weather-reporting station for local pressure.</string>
    <key>NSMotionUsageDescription</key>
    <string>Barry uses motion activity to gate the phone barometer — elevator rides and driving produce pressure changes that look like weather fronts. Motion gating keeps those out of the trend analysis.</string>
    <!-- Backend endpoint. Dev default is localhost; for device testing use your
         Mac's LAN IP, and for release use https://barry.wide-stack.com -->
    <key>BarryBackendURL</key>
    <string>http://127.0.0.1:8077</string>
    <!-- Dev only: allow plaintext HTTP to a local backend on your LAN.
         Remove this block once your backend is served over HTTPS. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <key>UILaunchScreen</key>
    <dict/>
</dict>
</plist>
